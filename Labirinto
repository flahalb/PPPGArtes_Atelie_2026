<html>
  <head>
    <title>Experiência de RA usando o AR.js e o A-frame, com meu marcador e imagem.</title>
    <script src="https://aframe.io/releases/1.3.0/aframe.min.js"></script>  
    <script src="https://cdn.jsdelivr.net/gh/AR-js-org/AR.js/aframe/build/aframe-ar.min.js"></script>
  </head>
  <body style="margin: 0; overflow: hidden;">
    <a-scene vr-mode-ui="enabled: false" embedded arjs="debugUIEnabled: false">
      <a-marker type="pattern" url="pattern-labirinto.patt">
        <a-image src="lamparina3D.png" position="0 0.5 0" rotation="-90 0 0" width="1.5" height="1"></a-image>
      </a-marker>
      <a-entity camera></a-entity>
    </a-scene>
    
  </body>
</html>
